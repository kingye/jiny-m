# GitHub token — used by gh CLI and git push/pull to github.com
# Create at: https://github.com/settings/tokens
GH_TOKEN=

# Git author for commits made inside the container
GIT_USER_NAME=kingye
GIT_USER_EMAIL=kingye@petalmail.com

# Paths to mount into the container
JINY_CONFIG_DIR=./.jiny
JINY_WORKSPACE_DIR=./workspace

# jiny-M .env file with secrets for config.json ${VAR} substitution
JINY_ENV_FILE=./.env.jiny

# OpenCode global config (API keys, providers, model settings)
OPENCODE_CONFIG=./opencode.jsonc
