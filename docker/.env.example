# API keys for AI models (required)
OPENCODE_API_KEY=
ANTHROPIC_API_KEY=

# GitHub token for PR workflow (optional)
GH_TOKEN=

# Paths to mount into the container
JINY_CONFIG_DIR=./.jiny
JINY_WORKSPACE_DIR=./workspace

# OpenCode global config (optional — for provider settings, model aliases, etc.)
# If not provided, OpenCode uses environment variables for API keys.
OPENCODE_CONFIG=./opencode.jsonc
